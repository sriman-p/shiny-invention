# =============================================================================
# ReqLens Example Environment File
# =============================================================================
#
# How to use this file:
#
#   1. Copy this file to a new file named .env:
#
#        cp .env.example .env
#
#   2. For basic local review, you can leave the values below as they are.
#
#   3. To run the full AI-backed pipeline, fill in at least one AI provider
#      key below or log in to one of the supported local agent CLIs.
#
# This .env file is read by the Django backend. It is intentionally ignored by
# Git so real API keys are not uploaded to GitHub.
#
# IMPORTANT:
# - Do not paste real secrets into .env.example.
# - Put real secrets only in .env.
# - Keep DJANGO_DEBUG=1 for local development.
# =============================================================================


# -----------------------------------------------------------------------------
# Django / Local App Settings
# -----------------------------------------------------------------------------

# Development secret used only for local runs.
# For production, replace this in .env with a long random value.
DJANGO_SECRET_KEY=dev-only-change-this-for-production

# 1 = local development mode.
# 0 = production-style mode.
DJANGO_DEBUG=1


# -----------------------------------------------------------------------------
# Optional AI Agent API Keys
# -----------------------------------------------------------------------------
#
# You do NOT need these keys just to:
# - install the app
# - open the browser UI
# - view seeded benchmark projects
# - inspect project configuration pages
#
# You DO need at least one configured agent/key to run real AI-backed pipeline
# stages such as Parse, Map, Generate, Critique, and Trace.
#
# Leave unused providers blank.
# -----------------------------------------------------------------------------

# Anthropic / Claude-style agent access.
# Example value format: sk-ant-...
ANTHROPIC_API_KEY=

# OpenAI / Codex-compatible agent access.
# Example value format: sk-...
OPENAI_API_KEY=

# Cursor SDK Composer 2 bridge and optional Cursor Agent authentication.
CURSOR_API_KEY=

# Google Gemini CLI agent access.
GEMINI_API_KEY=

# Blackbox CLI agent access.
BLACKBOX_API_KEY=


# -----------------------------------------------------------------------------
# Notes For Reviewers
# -----------------------------------------------------------------------------
#
# After copying this file to .env, run:
#
#   make setup
#   make dev-backend
#   make dev-frontend
#
# Then open:
#
#   http://localhost:3000
#
# The backend stores local data in:
#
#   backend/data/reqlens.db
#
# This database is generated locally and does not need to exist before setup.
# =============================================================================
