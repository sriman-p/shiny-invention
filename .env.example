# =============================================================================
# ReqLens Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# The .env file is loaded by Django settings via python-dotenv and is
# NOT committed to version control (it's in .gitignore).
#
# Usage: cp .env.example .env && edit .env
# =============================================================================

# -- Django Settings ----------------------------------------------------------

# Secret key used for cryptographic signing (sessions, CSRF tokens, etc.).
# MUST be changed to a unique, unpredictable value in production.
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production

# Enable Django debug mode. Set to "1" for development (verbose error pages,
# CORS allow-all, etc.) or "0" for production.
DJANGO_DEBUG=1

# -- ACP Agent API Keys ------------------------------------------------------
# Set the API key(s) for the AI agent(s) you want to use. You only need to
# set keys for agents you plan to invoke. The agents list endpoint
# (GET /api/v1/agents) will show which agents are available based on
# which keys are set and which CLI tools are installed.

# Anthropic API key for the Claude Code agent (claude-code).
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key for the Codex CLI agent (codex).
# Get yours at: https://platform.openai.com/
OPENAI_API_KEY=

# Google AI API key for the Gemini CLI agent (gemini).
# Get yours at: https://aistudio.google.com/
GEMINI_API_KEY=

# Blackbox API key for the Blackbox CLI agent (blackbox).
BLACKBOX_API_KEY=
